{
  "manifest_version": 3,
  "name": "Overleaf Comment Exporter",
  "version": "0.1.0",
  "description": "Export Overleaf review comments as CSV.",
  "homepage_url": "https://github.com/nmady/OverleafCommentExporter",
  "permissions": ["activeTab"],
  "host_permissions": ["https://www.overleaf.com/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Overleaf Comment Exporter",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.overleaf.com/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "overleaf-comment-exporter@nmady.github.io",
      "strict_min_version": "109.0"
    }
  }
}